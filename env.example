# Frontend Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# Backend API URL
# Development: http://localhost:3001
# Production: https://your-backend-url.onrender.com
# No API key is needed in the frontend. Paid services are only reached server-side
# when explicitly enabled by backend feature flags.
VITE_API_BASE_URL=http://localhost:3001

# Supabase Auth (frontend-safe values)
# Use only publishable/anon keys here. Never put SUPABASE_SERVICE_ROLE_KEY in Vite env.
VITE_AUTH_MODE=local
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=



