# Backend Environment Variables
# Copy this file to .env and fill in only what the selected mode needs.
# DO NOT commit .env to git.

# Server Configuration
# local: no paid services required, safe mocks enabled
# staging: real first-user test mode with Supabase Auth and a staging database
# production: strict auth recommended; real services only when explicitly enabled
APP_ENV=local
NODE_ENV=development
PORT=3001

# Feature flags / no-budget local mode
AI_PROVIDER_ENABLED=false
DATABASE_ENABLED=false
PAYMENT_ENABLED=false
SUPABASE_AUTH_ENABLED=false
AUTH_STRICT_MODE=false
USAGE_LIMITS_ENABLED=false
DEBUG_ENDPOINTS_ENABLED=true
LOCAL_AUTH_ENABLED=true

# Optional local-only secret overrides for fallback users.
# If set, the override and the dev fallback are both accepted locally.
# Never commit real passwords; keep them only in server/.env.
LOCAL_SECRET_LION=
LOCAL_SECRET_SELMA=
LOCAL_SECRET_ALICIA=
LOCAL_SECRET_MARIE=
LOCAL_SECRET_FRIEND5=
LOCAL_SECRET_SOPHIA=
LOCAL_SECRET_ISABELL=
LOCAL_SECRET_DOROTHEE=
LOCAL_SECRET_SERIGNE=
LOCAL_SECRET_BENJAMIN=
LOCAL_SECRET_ANNA=
LOCAL_SECRET_TUANA=

# Legacy weekly caps kept for older endpoints.
WEEKLY_FREE_INTERACTIONS=25
WEEKLY_COUNCIL_SESSIONS=5
WEEKLY_MEANING_ANALYSES=10

# Active free-tier/paywall limits
FREE_SINGLE_VOICE_REPLIES_PER_ARCHETYPE=6
FREE_COUNCIL_SESSIONS=5
FREE_COUNCIL_REPLIES_PER_SESSION=3
FREE_BLUEPRINT_SAVES=1
FREE_CYCLE_DAYS=5

# Beta access / paywall readiness.
# When DATABASE_ENABLED=true and staging_access_usage_v1.sql has run, these are
# counted in Supabase. Without database tables they fall back to process memory.
BETA_ACCESS_DAYS=14
BETA_PRICE_EUR=2.42

# Comma-separated account identifiers for staging exceptions.
# Supports exact user id/email/username and simple wildcards, e.g. lionceau*
# Founder access bypasses usage caps. Offline-only skips database persistence.
FOUNDER_ACCESS_IDENTIFIERS=
OFFLINE_ONLY_IDENTIFIERS=
ADMIN_IDENTIFIERS=

# JWT Authentication
# Required when AUTH_STRICT_MODE=true. In local no-budget mode, the server uses
# a development-only fallback so the app can run without credentials.
JWT_SECRET=

# OpenAI API
# Leave empty while AI_PROVIDER_ENABLED=false. No paid calls are made in mock mode.
# To enable live chat, set AI_PROVIDER_ENABLED=true and provide OPENAI_API_KEY.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS Configuration
# Comma-separated list of allowed frontend origins, no trailing slashes.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Supabase
# Leave empty while DATABASE_ENABLED=false. Reads/writes are disabled gracefully.
# SUPABASE_AUTH_ENABLED=true verifies Supabase Auth access tokens server-side.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional but recommended when SUPABASE_SERVICE_ROLE_KEY is a new sb_secret_... key.
# Supabase Auth admin operations such as listUsers/createUser may require the legacy service_role JWT (eyJ...).
SUPABASE_AUTH_ADMIN_KEY=

# Payments
# Leave empty while PAYMENT_ENABLED=false. Stripe secrets are backend-only.
# STRIPE_SECRET_KEY may also be provided through legacy PAYMENT_PROVIDER_SECRET.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BETA_PRICE_ID=
STRIPE_BETA_PAYMENT_LINK_URL=
FRONTEND_APP_URL=http://localhost:5173
PAYMENT_PROVIDER_SECRET=

# Staging baseline on Render:
# APP_ENV=staging
# NODE_ENV=production
# AI_PROVIDER_ENABLED=true
# DATABASE_ENABLED=true
# PAYMENT_ENABLED=true
# SUPABASE_AUTH_ENABLED=true
# AUTH_STRICT_MODE=true
# USAGE_LIMITS_ENABLED=true
# DEBUG_ENDPOINTS_ENABLED=true
# LOCAL_AUTH_ENABLED=false
# ALLOWED_ORIGINS=https://the-violet-eightfold-git-staging-the-violet-eightfolds-projects.vercel.app
# FREE_COUNCIL_SESSIONS=1
# FREE_COUNCIL_REPLIES_PER_SESSION=3
# FREE_SINGLE_VOICE_REPLIES_PER_ARCHETYPE=6
# FREE_BLUEPRINT_SAVES=1
# FREE_CYCLE_DAYS=5
# BETA_ACCESS_DAYS=14
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_BETA_PRICE_ID=price_...
# STRIPE_BETA_PAYMENT_LINK_URL=https://buy.stripe.com/test_...
# FRONTEND_APP_URL=https://the-violet-eightfold-git-staging-the-violet-eightfolds-projects.vercel.app
#
# Production baseline on Render:
# APP_ENV=production
# NODE_ENV=production
# AI_PROVIDER_ENABLED=true
# DATABASE_ENABLED=true
# PAYMENT_ENABLED=true
# SUPABASE_AUTH_ENABLED=true
# AUTH_STRICT_MODE=true
# USAGE_LIMITS_ENABLED=true
# DEBUG_ENDPOINTS_ENABLED=false
# LOCAL_AUTH_ENABLED=false
# ALLOWED_ORIGINS=https://app.lazarus-engine.eu,https://the-violet-eightfold42.vercel.app,https://the-violet-eightfold-git-main-the-violet-eightfolds-projects.vercel.app
# ADMIN_IDENTIFIERS=lionceaunicolai@yahoo.de
# FOUNDER_ACCESS_IDENTIFIERS=lionceaunicolai@yahoo.de
# SUPABASE_URL=<your-production-supabase-url>
# SUPABASE_SERVICE_ROLE_KEY=<your-production-service-role-key>
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_BETA_PRICE_ID=price_...
# STRIPE_BETA_PAYMENT_LINK_URL=https://buy.stripe.com/...
# FRONTEND_APP_URL=https://app.lazarus-engine.eu
